# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_ID=123456789

# OpenAI (direct, no OpenRouter)
OPENAI_API_KEY=sk-your-openai-key
# Use exact API model IDs for your OpenAI account
OPENAI_PRIMARY_MODEL=gpt-5.4-nano
OPENAI_FALLBACK_MODEL=gpt-5-mini

# Web search - Tavily (direct provider)
TAVILY_API_KEY=tvly-your-tavily-key
TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search

# Storage (Railway volume will provide /data in prod)
DATA_DIR=/data
TMP_DIR=/tmp/agent-files

# Agent behavior
MAX_AGENT_ITERATIONS=8
MAX_TOOL_OUTPUT_CHARS=12000
TELEGRAM_CHUNK_SIZE=3500

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGS=false
