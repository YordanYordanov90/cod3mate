# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_ID=123456789

# OpenAI (direct, no OpenRouter)
OPENAI_API_KEY=sk-your-openai-key
# Use exact API model IDs for your OpenAI account
OPENAI_PRIMARY_MODEL=gpt-5.4-nano
OPENAI_FALLBACK_MODEL=gpt-5-mini

# Web search - Tavily (direct provider)
TAVILY_API_KEY=tvly-your-tavily-key
TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search

# Storage (Railway volume will provide /data in prod)
DATA_DIR=/data
TMP_DIR=/tmp/agent-files

# Agent behavior
MAX_AGENT_ITERATIONS=8
QA_MAX_ITERATIONS=25
MAX_TOOL_OUTPUT_CHARS=12000
# Summarize older in-loop messages when history exceeds this size (0 = off)
AGENT_COMPACTION_THRESHOLD_CHARS=100000
AGENT_COMPACTION_KEEP_RECENT=8
# When true, every model call receives the full tool set (debug only)
AGENT_EXPOSE_ALL_TOOLS=false
TELEGRAM_CHUNK_SIZE=3500

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGS=false

# Dashboard API (OPTIONAL) — read-only HTTP layer for the private Vercel dashboard.
# Disabled by default; bot long-polling is unaffected. When DASHBOARD_API_ENABLED
# is true, DASHBOARD_API_TOKEN is REQUIRED (min 16 chars) and guards every
# /api/dashboard/* route via server-to-server bearer auth. /health stays public
# (Railway liveness). Never expose DASHBOARD_API_TOKEN to a browser.
# Port: DASHBOARD_API_PORT, else Railway PORT, else 8080.
DASHBOARD_API_ENABLED=false
DASHBOARD_API_TOKEN=
# DASHBOARD_API_PORT=8080

# Test credentials (OPTIONAL) — for browser-based login testing.
# When BOTH are set, the agent can fill login forms via the browser tools.
# Tell the agent in chat: "use the test credentials" with a target URL.
# The values are injected only into the system prompt under a strict
# "use silently, never echo" policy and registered with the central
# sanitizer, so they are redacted from chat output, summaries, and logs.
# Configure in Railway for production. NEVER commit real values.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=

# Phase 8: Multi-app credentials (alternative or in addition to legacy single above).
# Pattern: TEST_CREDENTIALS_<APP>_EMAIL and _PASSWORD (APP upper, e.g. CLOUDCASTAI, PINEFORGE).
# Agent prompt will list available app names + values; use by context (e.g. "test login on CloudcastAI").
# TEST_CREDENTIALS_CLOUDCASTAI_EMAIL=
# TEST_CREDENTIALS_CLOUDCASTAI_PASSWORD=
