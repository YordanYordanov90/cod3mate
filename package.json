{
  "name": "cod3mate",
  "version": "0.1.0",
  "private": true,
  "description": "Private Telegram-controlled AI agent with tools, deployed on Railway",
  "type": "module",
  "main": "dist/index.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dashboard:dev": "npm run dev --workspace apps/dashboard",
    "dashboard:build": "npm run build --workspace apps/dashboard",
    "dashboard:start": "npm run start --workspace apps/dashboard",
    "dashboard:lint": "npm run lint --workspace apps/dashboard",
    "dashboard:test": "vitest run tests/dashboard/frontend-api-client.test.ts"
  },
  "keywords": [
    "telegram",
    "ai-agent",
    "openai",
    "playwright",
    "railway"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@clerk/nextjs": "^7.4.3",
    "grammy": "^1.35.0",
    "openai": "^4.100.0",
    "playwright": "1.60.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
